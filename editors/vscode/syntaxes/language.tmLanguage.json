{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Siscript",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#types"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.siscript",
          "match": "//.*$"
        },
        {
          "name": "comment.block.siscript",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cstring.siscript",
          "begin": "c\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.siscript",
              "match": "\\\\([nrt0\"'\\\\/]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4})"
            }
          ]
        },
        {
          "name": "string.quoted.double.siscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.siscript",
              "match": "\\\\([nrt0\"'\\\\/]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4})"
            }
          ]
        },
        {
          "name": "string.quoted.single.char.siscript",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.siscript",
              "match": "\\\\([nrt0\"'\\\\/]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4})"
            }
          ]
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.siscript",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.siscript",
          "match": "\\b(if|else|while|for|return|match|in|break|continue)\\b"
        },
        {
          "name": "storage.type.function.siscript",
          "match": "\\b(fn)\\b"
        },
        {
          "name": "storage.type.siscript",
          "match": "\\b(let|const|struct|enum|type)\\b"
        },
        {
          "name": "storage.modifier.siscript",
          "match": "\\b(mut|extern|export)\\b"
        },
        {
          "name": "keyword.operator.cast.siscript",
          "match": "\\b(as)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.function.siscript"
            },
            "2": {
              "name": "entity.name.function.siscript"
            }
          }
        },
        {
          "name": "variable.function.siscript",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.siscript",
          "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|char|str|cstr|void)\\b"
        },
        {
          "name": "entity.name.type.siscript",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.siscript",
          "match": "\\b0x[0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.binary.siscript",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.octal.siscript",
          "match": "\\b0o[0-7_]+\\b"
        },
        {
          "name": "constant.numeric.float.siscript",
          "match": "\\b\\d+[0-9_]*\\.\\d+[0-9_]*\\b"
        },
        {
          "name": "constant.numeric.integer.siscript",
          "match": "\\b\\d+[0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.siscript",
          "match": "(\\+|\\-|\\*|/|%|=|==|!=|<|>|<=|>=|&&|\\|\\||!|&|\\||\\^|<<|>>|->|=>)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.siscript",
          "match": "(,|:|::)"
        },
        {
          "name": "punctuation.terminator.siscript",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.siscript",
          "match": "\\."
        }
      ]
    }
  },
  "scopeName": "source.siscript"
}
